{
  "name": "inspectra-platform",
  "version": "2.0.0",
  "private": true,
  "workspaces": ["frontend"],
  "scripts": {
    "dev": "concurrently -n API,WEB -c green,cyan \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev --workspace frontend",
    "dev:api": "python -m uvicorn app.main:app --reload --port 8000 --app-dir backend",
    "build": "npm run build --workspace frontend",
    "start:web": "npm run start --workspace frontend",
    "start:api": "python -m uvicorn app.main:app --host 0.0.0.0 --port 8000 --app-dir backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.15"
    }
  }
}
